# GeeGooAgent 运行时环境（由 geegoo CLI wrapper 与 start.sh 自动 source）
# 生产部署：与 config.json 保持一致，均指向 Go 3xxx；勿再写 5700/5800。
#
# cp agent.env.example ~/.geegoo/agent.env 后按实机填写密钥。

export GEEGOO_BOT_MCP_URL=http://118.195.135.97:3120
export GEEGOO_BOT_MCP_API_KEY=REPLACE_WITH_GEEGOO_BOT_MCP_API_KEY

export GEEGOO_SIGNAL_SIGNAL_API_URL=http://146.56.225.252:3200
export GEEGOO_SIGNAL_CATALOG_API_URL=http://146.56.225.252:3210
export GEEGOO_SIGNAL_SIGNAL_API_KEY=REPLACE_WITH_SIGNAL_API_KEY
export GEEGOO_SIGNAL_CATALOG_API_KEY=REPLACE_WITH_CATALOG_API_KEY

export GEEGOO_DATA_HTTP_URL=http://47.80.14.120:3300

export GEEGOO_CONFIG=/home/ubuntu/.geegoo/config.json
export PATH=/home/ubuntu/.geegoo/bin:/usr/local/go/bin:$PATH
